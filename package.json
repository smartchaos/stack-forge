  },
  "homepage": "https://github.com/smartchaos/stack-forge#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5",
    "inquirer": "^14.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.10",
